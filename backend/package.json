{
  "name": "opendesk-backend",
  "version": "0.1.0",
  "description": "OpenDesk AI — Core Backend & AI Brain",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "jest --selectProjects unit",
    "test:evals": "EVAL_MOCK=true jest --selectProjects evals --testPathPatterns agent.eval.test",
    "test:evals:live": "jest --selectProjects evals --testPathPatterns agent.eval.test --verbose",
    "test:all": "jest"
  },
  "keywords": [
    "opendesk",
    "ai",
    "autonomous-agent"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@types/multer": "^2.1.0",
    "bullmq": "^5.70.4",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.0",
    "mongoose": "^9.2.4",
    "multer": "^2.1.1",
    "openai": "^6.27.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.4.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}