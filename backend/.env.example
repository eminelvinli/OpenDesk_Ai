# OpenDesk AI — Backend Environment Variables
# Copy this file to .env and fill in values.

# Server
PORT=3001

# MongoDB
MONGODB_URI=mongodb://localhost:27017/opendesk

# Redis (for BullMQ and Pub/Sub)
REDIS_HOST=localhost
REDIS_PORT=6379

# LLM API Keys (encrypted at rest in production)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# JWT Secret (for device pairing auth)
# JWT_SECRET=
