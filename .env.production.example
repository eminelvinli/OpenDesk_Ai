# ──────────────────────────────────────────────────────────────────────────────
# OpenDesk AI — Production Environment Variables
#
# HOW TO USE:
#   cp .env.production.example .env.production
#   # Fill in all values — NEVER commit .env.production to git!
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d
#
# SECURITY: .env.production is already in .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────

# Semantic version tag for Docker image labels (e.g. v1.0.0)
APP_VERSION=v1.0.0

# ── MongoDB ───────────────────────────────────────────────────────────────────

# Root credentials for the MongoDB container.
MONGO_USERNAME=opendesk_admin
MONGO_PASSWORD=CHANGE_ME_STRONG_MONGO_PASSWORD

# Full connection URI used by the Node.js backend.
# Format: mongodb://username:password@host:port/dbname
MONGODB_URI=mongodb://opendesk_admin:CHANGE_ME_STRONG_MONGO_PASSWORD@mongodb:27017/opendesk?authSource=admin

# ── Redis ─────────────────────────────────────────────────────────────────────

# Password set on the Redis container.
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# Full connection URL used by Node.js backend + BullMQ.
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379

# Optional Redis host/port fields (used by services that prefer them separately).
REDIS_HOST=redis
REDIS_PORT=6379

# ── OpenAI Vision LLM ─────────────────────────────────────────────────────────

# Your OpenAI API key — keep this secret!
OPENAI_API_KEY=sk-...

# Model to use for Vision (recommended: gpt-4o for best quality/speed balance).
OPENAI_MODEL=gpt-4o

# ── JWT Authentication ────────────────────────────────────────────────────────

# Secret used to sign JWT tokens. Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_64_HEX_CHARS

# ── Service URLs (internal Docker network) ───────────────────────────────────

# Used by the Go Gateway to call backend REST endpoints.
BACKEND_URL=http://backend:3001

# Used by Gateway to publish/subscribe via Redis streams.
GATEWAY_REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379

# ── Frontend Public Variables ─────────────────────────────────────────────────
# These are BAKED INTO the Next.js build — must be set at build time.

# Public URL of the backend API (reachable from the browser).
NEXT_PUBLIC_API_URL=https://app.opendesk.ai

# Public WebSocket URL of the Go Gateway (used by Rust client + frontend).
NEXT_PUBLIC_GATEWAY_WS_URL=wss://gateway.opendesk.ai/ws

# ── Domains (Caddy TLS) ───────────────────────────────────────────────────────
# These must match your DNS A records pointing to this server's IP.
# Caddy will auto-provision Let's Encrypt certs for these.
#
# app.opendesk.ai     → Frontend + Backend API
# gateway.opendesk.ai → Go Gateway (WebSocket)
#
# Update caddy/Caddyfile with your actual domains if they differ.

# ── Logging ───────────────────────────────────────────────────────────────────

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── Email / Notifications (optional) ─────────────────────────────────────────

# SMTP settings for task completion / error notifications (optional).
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=CHANGE_ME
# NOTIFICATION_EMAIL=admin@opendesk.ai
