{
    "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/nicegui/static/tauri-v2/tauri.schema.json",
    "productName": "OpenDesk AI",
    "version": "0.1.0",
    "identifier": "ai.opendesk.client",
    "build": {
        "frontendDist": "../src",
        "devUrl": "http://localhost:1420"
    },
    "app": {
        "title": "OpenDesk AI",
        "windows": [
            {
                "title": "OpenDesk AI — Device Pairing",
                "width": 480,
                "height": 640,
                "resizable": true,
                "center": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}